<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_gradient_main">

    <!-- Top bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="20dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_arrow_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#FFFFFF"
            android:contentDescription="Back"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/settings_title"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_marginStart="4dp"/>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="32dp"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ═══ THEME ═══ -->
            <TextView style="@style/SectionLabel" android:text="THEME"/>

            <androidx.cardview.widget.CardView style="@style/GlassCard">
                <LinearLayout style="@style/CardInner">

                    <RadioGroup
                        android:id="@+id/rgTheme"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <RadioButton
                            android:id="@+id/rbThemeLight"
                            style="@style/GlassRadio"
                            android:text="  Light Mode"
                            android:drawableStart="@drawable/ic_light_mode"
                            android:drawablePadding="12dp"
                            android:paddingStart="12dp"/>
                        <View style="@style/Divider"/>
                        <RadioButton
                            android:id="@+id/rbThemeDark"
                            style="@style/GlassRadio"
                            android:text="  Dark Mode"
                            android:drawableStart="@drawable/ic_dark_mode"
                            android:drawablePadding="12dp"
                            android:paddingStart="12dp"/>

                    </RadioGroup>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ═══ LANGUAGES ═══ -->
            <TextView style="@style/SectionLabel" android:text="ACTIVE LANGUAGES"/>

            <androidx.cardview.widget.CardView style="@style/GlassCard">
                <LinearLayout style="@style/CardInner">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Choose which languages appear in the candidate bar"
                        android:textSize="12sp"
                        android:textColor="#AAFFFFFF"
                        android:layout_marginBottom="12dp"/>

                    <CheckBox android:id="@+id/cbLangEn" style="@style/GlassCheck" android:text="  English"/>
                    <View style="@style/Divider"/>
                    <CheckBox android:id="@+id/cbLangSi" style="@style/GlassCheck" android:text="  Sinhala (සිංහල)"/>
                    <View style="@style/Divider"/>
                    <CheckBox android:id="@+id/cbLangTa" style="@style/GlassCheck" android:text="  Tamil (தமிழ்)"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ═══ KEYBOARD LAYOUT ═══ -->
            <TextView style="@style/SectionLabel" android:text="KEYBOARD LAYOUT"/>

            <androidx.cardview.widget.CardView style="@style/GlassCard">
                <LinearLayout style="@style/CardInner">
                    <RadioGroup
                        android:id="@+id/rgSinhalaLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <RadioButton android:id="@+id/rbPhonetic"    style="@style/GlassRadio" android:text="Phonetic — type as you pronounce"/>
                        <View style="@style/Divider"/>
                        <RadioButton android:id="@+id/rbWijesekara"  style="@style/GlassRadio" android:text="Standard — Wijesekara / Tamil QWERTY"/>
                    </RadioGroup>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ═══ APPEARANCE ═══ -->
            <TextView style="@style/SectionLabel" android:text="APPEARANCE"/>

            <androidx.cardview.widget.CardView style="@style/GlassCard">
                <LinearLayout style="@style/CardInner">

                    <LinearLayout style="@style/RowLayout">
                        <LinearLayout style="@style/RowText">
                            <TextView style="@style/RowTitle" android:text="Number Row"/>
                            <TextView style="@style/RowSubtitle" android:text="Show 1–0 row at top of keyboard"/>
                        </LinearLayout>
                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/swNumberPad"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ═══ TYPING ═══ -->
            <TextView style="@style/SectionLabel" android:text="TYPING"/>

            <androidx.cardview.widget.CardView style="@style/GlassCard">
                <LinearLayout style="@style/CardInner">

                    <LinearLayout style="@style/RowLayout">
                        <LinearLayout style="@style/RowText">
                            <TextView style="@style/RowTitle" android:text="Word Predictions"/>
                            <TextView style="@style/RowSubtitle" android:text="Suggestions above keyboard"/>
                        </LinearLayout>
                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/swPredictions"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>
                    </LinearLayout>

                    <View style="@style/Divider"/>

                    <LinearLayout style="@style/RowLayout">
                        <LinearLayout style="@style/RowText">
                            <TextView style="@style/RowTitle" android:text="Popup Key Preview"/>
                            <TextView style="@style/RowSubtitle" android:text="Show enlarged letter on press"/>
                        </LinearLayout>
                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/swPopupKeys"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>
</LinearLayout>