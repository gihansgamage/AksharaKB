<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_main">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- THEME SECTION -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="THEME"
            android:textSize="12sp"
            android:textColor="@color/primary"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:layout_marginBottom="8dp"
            android:layout_marginTop="8dp"/>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/card_bg">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <RadioGroup
                    android:id="@+id/rgTheme"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <RadioButton
                        android:id="@+id/rb_theme_default"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="☀️  Default (Light)"
                        android:textSize="15sp"
                        android:gravity="center_vertical"
                        android:textColor="@color/text_primary"/>

                    <RadioButton
                        android:id="@+id/rb_theme_dark"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="🌑  Dark"
                        android:textSize="15sp"
                        android:gravity="center_vertical"
                        android:textColor="@color/text_primary"/>

                    <RadioButton
                        android:id="@+id/rb_theme_ocean"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="🌊  Ocean Blue"
                        android:textSize="15sp"
                        android:gravity="center_vertical"
                        android:textColor="@color/text_primary"/>

                    <RadioButton
                        android:id="@+id/rb_theme_sunset"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="🌅  Sunset Purple"
                        android:textSize="15sp"
                        android:gravity="center_vertical"
                        android:textColor="@color/text_primary"/>

                </RadioGroup>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/divider"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="8dp"/>

                <Button
                    android:id="@+id/btnSetBg"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="🖼️  Custom Background Image"
                    android:textAllCaps="false"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

                <Button
                    android:id="@+id/btnClearBg"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="Clear Custom Background"
                    android:textAllCaps="false"
                    android:layout_marginTop="8dp"
                    style="@style/Widget.MaterialComponents.Button.TextButton"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- APPEARANCE SECTION -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="APPEARANCE"
            android:textSize="12sp"
            android:textColor="@color/primary"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:layout_marginBottom="8dp"/>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/card_bg">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Border toggle -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Show Key Borders"
                            android:textSize="15sp"
                            android:textColor="@color/text_primary"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Draw outline around keys"
                            android:textSize="12sp"
                            android:textColor="@color/text_secondary"/>

                    </LinearLayout>

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/swBorder"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/divider"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="4dp"/>

                <!-- Key Height -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Key Height"
                    android:textSize="15sp"
                    android:textColor="@color/text_primary"
                    android:layout_marginTop="8dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="8dp">

                    <SeekBar
                        android:id="@+id/seekKeyHeight"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:max="30"
                        android:progress="10"/>

                    <TextView
                        android:id="@+id/tvKeyHeightValue"
                        android:layout_width="60dp"
                        android:layout_height="wrap_content"
                        android:text="50dp"
                        android:textSize="14sp"
                        android:textColor="@color/text_secondary"
                        android:gravity="end"
                        android:layout_marginStart="12dp"/>

                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- SINHALA LAYOUT SECTION -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="SINHALA LAYOUT"
            android:textSize="12sp"
            android:textColor="@color/primary"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:layout_marginBottom="8dp"/>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/card_bg">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <RadioGroup
                    android:id="@+id/rgSinhalaLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <RadioButton
                        android:id="@+id/rb_phonetic"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="Phonetic (Easy typing)"
                        android:textSize="15sp"
                        android:gravity="center_vertical"
                        android:textColor="@color/text_primary"/>

                    <RadioButton
                        android:id="@+id/rb_wijesekara"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="Wijesekara (Standard)"
                        android:textSize="15sp"
                        android:gravity="center_vertical"
                        android:textColor="@color/text_primary"/>

                </RadioGroup>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- TYPING SECTION -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="TYPING"
            android:textSize="12sp"
            android:textColor="@color/primary"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:layout_marginBottom="8dp"/>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="32dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/card_bg">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Vibrate -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Vibrate on Keypress"
                        android:textSize="15sp"
                        android:textColor="@color/text_primary"/>

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/swVibrate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/divider"/>

                <!-- Sound -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Sound on Keypress"
                        android:textSize="15sp"
                        android:textColor="@color/text_primary"/>

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/swSound"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/divider"/>

                <!-- Predictions -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Word &amp; Emoji Predictions"
                            android:textSize="15sp"
                            android:textColor="@color/text_primary"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Show suggestions above keyboard"
                            android:textSize="12sp"
                            android:textColor="@color/text_secondary"/>

                    </LinearLayout>

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/swPredictions"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>

</ScrollView>