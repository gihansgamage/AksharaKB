<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_gradient_main">

    <!-- Top bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="20dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_arrow_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#FFFFFF"
            android:contentDescription="Back"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/settings_title"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_marginStart="4dp"/>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="32dp"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ═══ THEME ═══ -->
            <TextView style="@style/SectionLabel" android:text="THEME"/>

            <androidx.cardview.widget.CardView style="@style/GlassCard">
                <LinearLayout style="@style/CardInner">

                    <RadioGroup
                        android:id="@+id/rgTheme"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <RadioButton
                            android:id="@+id/rbThemeLight"
                            style="@style/GlassRadio"
                            android:text="☀  Light"/>
                        <View style="@style/Divider"/>
                        <RadioButton
                            android:id="@+id/rbThemeDark"
                            style="@style/GlassRadio"
                            android:text="◑  Dark"/>

                    </RadioGroup>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ═══ LANGUAGES ═══ -->
            <TextView style="@style/SectionLabel" android:text="ACTIVE LANGUAGES"/>

            <androidx.cardview.widget.CardView style="@style/GlassCard">
                <LinearLayout style="@style/CardInner">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Choose which languages appear in the candidate bar"
                        android:textSize="12sp"
                        android:textColor="#AAFFFFFF"
                        android:layout_marginBottom="12dp"/>

                    <CheckBox android:id="@+id/cbLangEn" style="@style/GlassCheck" android:text="  English"/>
                    <View style="@style/Divider"/>
                    <CheckBox android:id="@+id/cbLangSi" style="@style/GlassCheck" android:text="  Sinhala (සිංහල)"/>
                    <View style="@style/Divider"/>
                    <CheckBox android:id="@+id/cbLangTa" style="@style/GlassCheck" android:text="  Tamil (தமிழ்)"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ═══ SINHALA LAYOUT ═══ -->
            <TextView style="@style/SectionLabel" android:text="SINHALA LAYOUT"/>

            <androidx.cardview.widget.CardView style="@style/GlassCard">
                <LinearLayout style="@style/CardInner">
                    <RadioGroup
                        android:id="@+id/rgSinhalaLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <RadioButton android:id="@+id/rbPhonetic"    style="@style/GlassRadio" android:text="Phonetic — type as you pronounce"/>
                        <View style="@style/Divider"/>
                        <RadioButton android:id="@+id/rbWijesekara"  style="@style/GlassRadio" android:text="Wijesekara — standard Sri Lankan layout"/>
                    </RadioGroup>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ═══ APPEARANCE ═══ -->
            <TextView style="@style/SectionLabel" android:text="APPEARANCE"/>

            <androidx.cardview.widget.CardView style="@style/GlassCard">
                <LinearLayout style="@style/CardInner">

                    <LinearLayout style="@style/RowLayout">
                        <LinearLayout style="@style/RowText">
                            <TextView style="@style/RowTitle" android:text="Show Key Borders"/>
                            <TextView style="@style/RowSubtitle" android:text="Outline around each key"/>
                        </LinearLayout>
                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/swBorder"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>
                    </LinearLayout>

                    <View style="@style/Divider"/>

                    <LinearLayout style="@style/RowLayout">
                        <LinearLayout style="@style/RowText">
                            <TextView style="@style/RowTitle" android:text="Number Row"/>
                            <TextView style="@style/RowSubtitle" android:text="Show 1–0 row at top of keyboard"/>
                        </LinearLayout>
                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/swNumberPad"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>
                    </LinearLayout>

                    <View style="@style/Divider"/>

                    <!-- Key Height -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingTop="12dp"
                        android:paddingBottom="4dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="10dp">
                            <TextView style="@style/RowTitle"
                                android:layout_width="0dp"
                                android:layout_weight="1"
                                android:text="Key Height"/>
                            <TextView
                                android:id="@+id/tvKeyHeightValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="52dp"
                                android:textSize="13sp"
                                android:textColor="#AAFFFFFF"/>
                        </LinearLayout>

                        <SeekBar
                            android:id="@+id/seekKeyHeight"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:max="30"
                            android:progress="12"
                            android:progressTint="#FFFFFF"
                            android:thumbTint="#FFFFFF"/>
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ═══ TYPING ═══ -->
            <TextView style="@style/SectionLabel" android:text="TYPING"/>

            <androidx.cardview.widget.CardView style="@style/GlassCard">
                <LinearLayout style="@style/CardInner">

                    <LinearLayout style="@style/RowLayout">
                        <LinearLayout style="@style/RowText">
                            <TextView style="@style/RowTitle" android:text="Vibrate on Keypress"/>
                        </LinearLayout>
                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/swVibrate"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>
                    </LinearLayout>

                    <View style="@style/Divider"/>

                    <LinearLayout style="@style/RowLayout">
                        <LinearLayout style="@style/RowText">
                            <TextView style="@style/RowTitle" android:text="Sound on Keypress"/>
                        </LinearLayout>
                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/swSound"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>
                    </LinearLayout>

                    <View style="@style/Divider"/>

                    <LinearLayout style="@style/RowLayout">
                        <LinearLayout style="@style/RowText">
                            <TextView style="@style/RowTitle" android:text="Word Predictions"/>
                            <TextView style="@style/RowSubtitle" android:text="Suggestions above keyboard"/>
                        </LinearLayout>
                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/swPredictions"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>
                    </LinearLayout>

                    <View style="@style/Divider"/>

                    <LinearLayout style="@style/RowLayout">
                        <LinearLayout style="@style/RowText">
                            <TextView style="@style/RowTitle" android:text="Popup Key Preview"/>
                            <TextView style="@style/RowSubtitle" android:text="Show enlarged letter on press"/>
                        </LinearLayout>
                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/swPopupKeys"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>
</LinearLayout>