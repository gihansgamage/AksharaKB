<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient_main"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="56dp"
        android:paddingBottom="40dp">

        <!-- App icon + title -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="32dp">

            <ImageView
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:src="@mipmap/ic_launcher"
                android:background="@drawable/icon_bg"
                android:padding="2dp"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="AksharaKB"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:letterSpacing="-0.02"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sinhala · Tamil · English"
                    android:textSize="13sp"
                    android:textColor="#AAFFFFFF"/>

            </LinearLayout>
        </LinearLayout>

        <!-- Step 1 Card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/step1Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#22FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">

                    <TextView
                        android:id="@+id/step1Badge"
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:text="1"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        android:gravity="center"
                        android:background="@drawable/badge_circle"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Enable AksharaKB"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:layout_marginStart="12dp"/>
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Settings → System → Language &amp; Input → Manage Keyboards → Enable AksharaKB"
                    android:textSize="13sp"
                    android:textColor="#BBFFFFFF"
                    android:lineSpacingExtra="3dp"
                    android:layout_marginBottom="14dp"/>

                <Button
                    android:id="@+id/btnEnableKeyboard"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="@string/enable_keyboard"
                    android:textAllCaps="false"
                    android:textSize="15sp"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/btn_glass"
                    android:stateListAnimator="@null"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Step 2 Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#22FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">

                    <TextView
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:text="2"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        android:gravity="center"
                        android:background="@drawable/badge_circle"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Select AksharaKB"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:layout_marginStart="12dp"/>
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Tap any text field → tap the keyboard icon → switch to AksharaKB"
                    android:textSize="13sp"
                    android:textColor="#BBFFFFFF"
                    android:lineSpacingExtra="3dp"
                    android:layout_marginBottom="14dp"/>

                <Button
                    android:id="@+id/btnSelectKeyboard"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="Switch Keyboard"
                    android:textAllCaps="false"
                    android:textSize="15sp"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/btn_glass_outline"
                    android:stateListAnimator="@null"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Settings CTA -->
        <Button
            android:id="@+id/btnOpenSettings"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:text="Keyboard Settings"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            android:background="@drawable/btn_primary"
            android:drawableStart="@drawable/ic_settings_gear"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:drawablePadding="12dp"
            android:layout_marginTop="6dp"
            android:stateListAnimator="@null"/>

        <Button
            android:id="@+id/btnUserGuide"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:text="Phonetic User Guide"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            android:background="@drawable/btn_glass_outline"
            android:drawableStart="@drawable/ic_book"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:drawablePadding="12dp"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="28dp"
            android:stateListAnimator="@null"/>

        <!-- Features card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            style="@style/GlassCard">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Key Features"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:layout_marginBottom="16dp"/>

                <GridLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:columnCount="2"
                    android:alignmentMode="alignMargins"
                    android:columnOrderPreserved="false"
                    android:useDefaultMargins="true">

                    <!-- Phonetic & Wijesekara -->
                    <LinearLayout android:layout_width="0dp" android:layout_gravity="fill_horizontal" android:layout_columnWeight="1" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="12dp">
                        <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@drawable/ic_keyboard" app:tint="#AAFFFFFF"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Phonetic &amp; Wij" android:textSize="13sp" android:textColor="#DDFFFFFF" android:layout_marginStart="8dp"/>
                    </LinearLayout>

                    <!-- Tamil -->
                    <LinearLayout android:layout_width="0dp" android:layout_gravity="fill_horizontal" android:layout_columnWeight="1" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="12dp">
                        <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@drawable/ic_language_alt" app:tint="#AAFFFFFF"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Tamil Layout" android:textSize="13sp" android:textColor="#DDFFFFFF" android:layout_marginStart="8dp"/>
                    </LinearLayout>

                    <!-- English -->
                    <LinearLayout android:layout_width="0dp" android:layout_gravity="fill_horizontal" android:layout_columnWeight="1" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="12dp">
                        <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@drawable/ic_globe" app:tint="#AAFFFFFF"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="English QWERTY" android:textSize="13sp" android:textColor="#DDFFFFFF" android:layout_marginStart="8dp"/>
                    </LinearLayout>

                    <!-- Predictions -->
                    <LinearLayout android:layout_width="0dp" android:layout_gravity="fill_horizontal" android:layout_columnWeight="1" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="12dp">
                        <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@drawable/ic_magic" app:tint="#AAFFFFFF"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Word Prediction" android:textSize="13sp" android:textColor="#DDFFFFFF" android:layout_marginStart="8dp"/>
                    </LinearLayout>

                    <!-- Themes -->
                    <LinearLayout android:layout_width="0dp" android:layout_gravity="fill_horizontal" android:layout_columnWeight="1" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="12dp">
                        <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@drawable/ic_theme" app:tint="#AAFFFFFF"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Custom Themes" android:textSize="13sp" android:textColor="#DDFFFFFF" android:layout_marginStart="8dp"/>
                    </LinearLayout>

                    <!-- Clipboard -->
                    <LinearLayout android:layout_width="0dp" android:layout_gravity="fill_horizontal" android:layout_columnWeight="1" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="12dp">
                        <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@drawable/ic_clipboard" app:tint="#AAFFFFFF"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Clipboard Hist" android:textSize="13sp" android:textColor="#DDFFFFFF" android:layout_marginStart="8dp"/>
                    </LinearLayout>

                </GridLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <TextView
            android:id="@+id/btnWebsite"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Visit Website"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:gravity="center"
            android:layout_marginTop="8dp"
            android:padding="8dp"
            android:background="?attr/selectableItemBackground"
            android:alpha="0.8"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Developed by Gihan S Gamage"
            android:textColor="#88FFFFFF"
            android:textSize="12sp"
            android:gravity="center"
            android:layout_marginTop="16dp"
            android:alpha="0.7"/>

    </LinearLayout>
</ScrollView>