<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@android:color/transparent">

    <!-- Candidate / action bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="46dp"
        android:orientation="horizontal"
        android:background="@drawable/candidate_bar_bg"
        android:gravity="center_vertical"
        android:paddingStart="4dp"
        android:paddingEnd="4dp">

        <!-- Language pills -->
        <LinearLayout
            android:id="@+id/lang_pills_container"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="4dp"
            android:paddingEnd="2dp"/>

        <!-- Divider -->
        <View
            android:layout_width="0.5dp"
            android:layout_height="18dp"
            android:background="#28FFFFFF"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"/>

        <!-- Word suggestions (scrollable, fills remaining space) -->
        <HorizontalScrollView
            android:id="@+id/candidates_view"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:scrollbars="none"
            android:overScrollMode="never"
            android:background="@android:color/transparent">
            <LinearLayout
                android:id="@+id/candidates_container"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="4dp"
                android:paddingEnd="4dp"/>
        </HorizontalScrollView>

        <!-- Divider -->
        <View
            android:layout_width="0.5dp"
            android:layout_height="18dp"
            android:background="#28FFFFFF"
            android:layout_marginStart="2dp"
            android:layout_marginEnd="2dp"/>

        <!-- Emoji toggle  ☺ U+263A -->
        <TextView
            android:id="@+id/btn_emoji"
            android:layout_width="40dp"
            android:layout_height="46dp"
            android:text="&#9786;"
            android:textSize="17sp"
            android:textColor="#AAFFFFFF"
            android:gravity="center"
            android:background="@android:color/transparent"/>

        <!-- Divider -->
        <View
            android:layout_width="0.5dp"
            android:layout_height="18dp"
            android:background="#28FFFFFF"/>

        <!-- Keyboard mode  -->
        <TextView
            android:id="@+id/btn_kb_mode"
            android:layout_width="40dp"
            android:layout_height="46dp"
            android:text="Wij"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="#AAFFFFFF"
            android:gravity="center"
            android:fontFamily="sans-serif-medium"
            android:background="@android:color/transparent"/>

        <!-- Divider -->
        <View
            android:layout_width="0.5dp"
            android:layout_height="18dp"
            android:background="#28FFFFFF"/>

        <!-- Settings  ⚙ U+2699 -->
        <TextView
            android:id="@+id/btn_settings"
            android:layout_width="40dp"
            android:layout_height="46dp"
            android:text="&#9881;"
            android:textSize="17sp"
            android:textColor="#AAFFFFFF"
            android:gravity="center"
            android:background="@android:color/transparent"/>

    </LinearLayout>

    <!-- The keyboard — no outer border, spacing all in MyKeyboardView.kt -->
    <com.gihansgamage.aksharakb.MyKeyboardView
        android:id="@+id/keyboard_view"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        android:keyPreviewLayout="@layout/key_preview"
        android:keyTextColor="#00000000"
        android:keyBackground="@android:color/transparent"
        android:shadowColor="#00000000"
        android:shadowRadius="0"
        android:paddingBottom="6dp"/>

</LinearLayout>