<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@android:color/transparent">

    <!-- Candidate / action bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="46dp"
        android:orientation="horizontal"
        android:background="@drawable/candidate_bar_bg"
        android:gravity="center_vertical">

        <!-- Language pills -->
        <LinearLayout
            android:id="@+id/lang_pills_container"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="6dp"
            android:paddingEnd="2dp"/>

        <View android:layout_width="0.5dp" android:layout_height="20dp"
            android:background="#33FFFFFF"
            android:layout_marginStart="4dp" android:layout_marginEnd="4dp"/>

        <!-- Word suggestion chips (scrollable) -->
        <HorizontalScrollView
            android:id="@+id/candidates_view"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:scrollbars="none"
            android:overScrollMode="never"
            android:background="@android:color/transparent">
            <LinearLayout
                android:id="@+id/candidates_container"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="4dp"
                android:paddingEnd="4dp"/>
        </HorizontalScrollView>

        <View android:layout_width="0.5dp" android:layout_height="20dp"
            android:background="#33FFFFFF"
            android:layout_marginStart="2dp" android:layout_marginEnd="2dp"/>

        <!-- Emoji panel — ☺ symbol (U+263A) -->
        <TextView
            android:id="@+id/btn_emoji"
            android:layout_width="42dp"
            android:layout_height="46dp"
            android:text="&#9786;"
            android:textSize="18sp"
            android:textColor="#99FFFFFF"
            android:gravity="center"
            android:background="@android:color/transparent"/>

        <View android:layout_width="0.5dp" android:layout_height="20dp"
            android:background="#33FFFFFF"/>

        <!-- Keyboard mode (Wij / Pho / ABC) -->
        <TextView
            android:id="@+id/btn_kb_mode"
            android:layout_width="40dp"
            android:layout_height="46dp"
            android:text="Wij"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="#99FFFFFF"
            android:gravity="center"
            android:fontFamily="sans-serif-medium"
            android:background="@android:color/transparent"/>

        <View android:layout_width="0.5dp" android:layout_height="20dp"
            android:background="#33FFFFFF"/>

        <!-- Settings — ⚙ gear (U+2699) -->
        <TextView
            android:id="@+id/btn_settings"
            android:layout_width="42dp"
            android:layout_height="46dp"
            android:text="&#9881;"
            android:textSize="18sp"
            android:textColor="#99FFFFFF"
            android:gravity="center"
            android:background="@android:color/transparent"/>

    </LinearLayout>

    <!-- Keyboard view — no border, spacing done in MyKeyboardView.kt -->
    <com.gihansgamage.aksharakb.MyKeyboardView
        android:id="@+id/keyboard_view"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        android:keyPreviewLayout="@layout/key_preview"
        android:keyTextColor="#00000000"
        android:keyBackground="@android:color/transparent"
        android:shadowColor="#00000000"
        android:shadowRadius="0"
        android:paddingBottom="6dp"/>

</LinearLayout>