<?xml version="1.0" encoding="utf-8"?>
<!--
  Root has NO horizontal padding — keyboard must span full screen width.
  The candidate bar has its own horizontal margins so it floats as a pill.
  MyKeyboardView draws its own gap (2.6dp) so edge keys are never clipped.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@android:color/transparent"
    android:paddingTop="6dp">

    <!-- ── Candidate bar — floats as a rounded pill, same bg as keyboard ── -->
    <LinearLayout
        android:id="@+id/candidate_bar"
        android:layout_width="match_parent"
        android:layout_height="46dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="10dp"
        android:paddingEnd="6dp"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginBottom="4dp"
        android:background="@drawable/candidate_bar_pill">

        <!-- Single language switch icon — shows current language, tap to cycle -->
        <TextView
            android:id="@+id/btn_lang_single"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:text="&#9000;"
            android:textSize="15sp"
            android:textColor="#CCFFFFFF"
            android:gravity="center"
            android:background="@android:color/transparent"/>

        <!-- Language pills container — hidden but kept for IME compat -->
        <LinearLayout
            android:id="@+id/lang_pills_container"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone"/>

        <!-- Divider -->
        <View
            android:layout_width="0.5dp"
            android:layout_height="18dp"
            android:background="#33FFFFFF"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"/>

        <!-- Word predictions (scrollable, fills remaining space) -->
        <HorizontalScrollView
            android:id="@+id/candidates_view"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:scrollbars="none"
            android:overScrollMode="never"
            android:background="@android:color/transparent">
            <LinearLayout
                android:id="@+id/candidates_container"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center_vertical"/>
        </HorizontalScrollView>

        <!-- Divider -->
        <View
            android:layout_width="0.5dp"
            android:layout_height="18dp"
            android:background="#33FFFFFF"
            android:layout_marginStart="2dp"
            android:layout_marginEnd="2dp"/>

        <!-- Emoji ☺ U+263A -->
        <TextView
            android:id="@+id/btn_emoji"
            android:layout_width="38dp"
            android:layout_height="46dp"
            android:text="&#9786;"
            android:textSize="17sp"
            android:textColor="#CCFFFFFF"
            android:gravity="center"
            android:background="@android:color/transparent"/>

        <!-- Divider -->
        <View
            android:layout_width="0.5dp"
            android:layout_height="18dp"
            android:background="#33FFFFFF"/>

        <!-- Settings ⚙ U+2699 -->
        <TextView
            android:id="@+id/btn_settings"
            android:layout_width="38dp"
            android:layout_height="46dp"
            android:text="&#9881;"
            android:textSize="17sp"
            android:textColor="#CCFFFFFF"
            android:gravity="center"
            android:background="@android:color/transparent"/>

    </LinearLayout>

    <!-- ── Keyboard — full width, no padding on container ── -->
    <com.gihansgamage.aksharakb.MyKeyboardView
        android:id="@+id/keyboard_view"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        android:keyPreviewLayout="@layout/key_preview"
        android:keyTextColor="#00000000"
        android:keyBackground="@android:color/transparent"
        android:shadowColor="#00000000"
        android:shadowRadius="0"
        android:paddingBottom="8dp"/>

</LinearLayout>