<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- ═══════════════════════════════════════════════════════════
         DARK THEME STYLES  (default — used when theme = dark)
         ═══════════════════════════════════════════════════════════ -->

    <!-- Glass card — frosted semi-transparent dark panel -->
    <style name="GlassCard" parent="">
        <item name="cardCornerRadius">24dp</item>
        <item name="cardElevation">0dp</item>
        <item name="cardBackgroundColor">#1EFFFFFF</item>
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginBottom">16dp</item>
    </style>

    <!-- Card inner -->
    <style name="CardInner">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:orientation">vertical</item>
        <item name="android:padding">18dp</item>
    </style>

    <!-- Section header -->
    <style name="SectionLabel">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">11sp</item>
        <item name="android:textColor">#88FFFFFF</item>
        <item name="android:letterSpacing">0.14</item>
        <item name="android:layout_marginStart">4dp</item>
        <item name="android:layout_marginTop">20dp</item>
        <item name="android:layout_marginBottom">6dp</item>
    </style>

    <!-- Radio button — white text on dark -->
    <style name="GlassRadio">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">52dp</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:paddingStart">4dp</item>
        <item name="android:buttonTint">#FFFFFF</item>
        <item name="android:gravity">center_vertical</item>
    </style>

    <!-- Checkbox — white text on dark -->
    <style name="GlassCheck">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">52dp</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:paddingStart">4dp</item>
        <item name="android:buttonTint">#FFFFFF</item>
        <item name="android:gravity">center_vertical</item>
    </style>

    <!-- Thin divider -->
    <style name="Divider">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">0.8dp</item>
        <item name="android:background">#1EFFFFFF</item>
    </style>

    <!-- Row outer container -->
    <style name="RowLayout">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">56dp</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:gravity">center_vertical</item>
    </style>

    <!-- Row text column -->
    <style name="RowText">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:orientation">vertical</item>
    </style>

    <!-- Row primary label -->
    <style name="RowTitle">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textColor">#FFFFFF</item>
    </style>

    <!-- Row secondary label -->
    <style name="RowSubtitle">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">#88FFFFFF</item>
        <item name="android:layout_marginTop">2dp</item>
    </style>

</resources>