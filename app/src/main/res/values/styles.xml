<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Glass card -->
    <style name="GlassCard" parent="">
        <item name="cardCornerRadius">20dp</item>
        <item name="cardElevation">0dp</item>
        <item name="cardBackgroundColor">#22FFFFFF</item>
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginBottom">14dp</item>
    </style>

    <!-- Card inner linear layout -->
    <style name="CardInner">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:orientation">vertical</item>
        <item name="android:padding">18dp</item>
    </style>

    <!-- Section header label -->
    <style name="SectionLabel">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">11sp</item>
        <item name="android:textColor">#AAFFFFFF</item>
        <item name="android:letterSpacing">0.12</item>
        <item name="android:layout_marginStart">4dp</item>
        <item name="android:layout_marginTop">18dp</item>
        <item name="android:layout_marginBottom">6dp</item>
    </style>

    <!-- Glass radio button -->
    <style name="GlassRadio">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">48dp</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:paddingStart">4dp</item>
        <item name="android:buttonTint">#FFFFFF</item>
        <item name="android:gravity">center_vertical</item>
    </style>

    <!-- Glass checkbox -->
    <style name="GlassCheck">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">48dp</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:paddingStart">4dp</item>
        <item name="android:buttonTint">#FFFFFF</item>
        <item name="android:gravity">center_vertical</item>
    </style>

    <!-- Thin divider -->
    <style name="Divider">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">0.8dp</item>
        <item name="android:background">#22FFFFFF</item>
    </style>

    <!-- Settings row outer layout -->
    <style name="RowLayout">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">56dp</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:gravity">center_vertical</item>
    </style>

    <!-- Settings row text column -->
    <style name="RowText">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:orientation">vertical</item>
    </style>

    <!-- Row title -->
    <style name="RowTitle">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">#FFFFFF</item>
    </style>

    <!-- Row subtitle -->
    <style name="RowSubtitle">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">#99FFFFFF</item>
        <item name="android:layout_marginTop">2dp</item>
    </style>

</resources>