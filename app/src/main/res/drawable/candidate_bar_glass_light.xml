<?xml version="1.0" encoding="utf-8"?>
<!--
  Candidate bar — LIGHT theme.
  Matches key liquid glass: 60% opacity white (#99), subtle shine, minimal border.
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Drop shadow -->
    <item android:left="2dp" android:top="3dp" android:right="2dp" android:bottom="-3dp">
        <shape android:shape="rectangle">
            <solid android:color="#22000044"/>
            <corners android:radius="250dp"/>
        </shape>
    </item>

    <!-- Glass body — matches key opacity 60% (#99) -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#99FFFFFF"/>
            <corners android:radius="250dp"/>
        </shape>
    </item>

    <!-- Top shine -->
    <item android:bottom="23dp">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#18FFFFFF"
                android:endColor="#00FFFFFF"
                android:angle="270"
                android:type="linear"/>
            <corners android:radius="250dp"/>
        </shape>
    </item>

    <!-- Rim border -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#00000000"/>
            <stroke android:width="0.7dp" android:color="#22000066"/>
            <corners android:radius="250dp"/>
        </shape>
    </item>

</layer-list>