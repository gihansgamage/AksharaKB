<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Soft shadow underneath -->
    <item android:left="6dp" android:top="4dp" android:right="6dp" android:bottom="-4dp">
        <shape android:shape="rectangle">
            <solid android:color="#33000000"/>
            <corners android:radius="250dp"/>
        </shape>
    </item>
    <!-- Main glass body — pure grey, no border -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#55404040"/>
            <corners android:radius="250dp"/>
        </shape>
    </item>
    <!-- Left fade -->
    <item android:right="23dp">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#00000000"
                android:endColor="#00000000"
                android:angle="0"
                android:type="linear"/>
            <corners android:radius="250dp"/>
        </shape>
    </item>
    <!-- Top shine gradient -->
    <item android:bottom="24dp">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#12FFFFFF"
                android:endColor="#00FFFFFF"
                android:angle="270"
                android:type="linear"/>
            <corners android:radius="250dp"/>
        </shape>
    </item>
</layer-list>