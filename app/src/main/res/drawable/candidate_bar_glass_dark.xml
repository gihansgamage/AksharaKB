<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Frosted glass body -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#CC1E2030"/>
            <corners android:radius="250dp"/>
        </shape>
    </item>
    <!-- Top shine — covers top 23dp of the 46dp bar -->
    <item android:bottom="23dp">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#0EFFFFFF"
                android:endColor="#00FFFFFF"
                android:angle="270"
                android:type="linear"/>
            <corners android:radius="250dp"/>
        </shape>
    </item>
</layer-list>