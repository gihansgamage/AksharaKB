        <Key android:codes="-5" android:keyLabel="⌫"
            android:keyWidth="10%p" android:keyEdgeFlags="right"
            android:isRepeatable="true"/>
    </Row>

    <Row android:rowEdgeFlags="bottom">
        <Key android:codes="-2" android:keyLabel="\?123" android:keyWidth="15%p" android:keyEdgeFlags="left"/>
        <Key android:codes="44" android:keyLabel="," android:keyWidth="12%p"/>
        <Key android:codes="32" android:keyLabel="space" android:keyWidth="46%p"/>
        <Key android:codes="46" android:keyLabel="." android:keyWidth="12%p"/>
        <Key android:codes="-4" android:keyLabel="↵" android:keyWidth="15%p" android:keyEdgeFlags="right"/>
