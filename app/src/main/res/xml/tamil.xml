        <Key android:codes="2980" android:keyLabel="த" android:popupCharacters="ந" android:keyEdgeFlags="right"/>
    </Row>

    <Row>
        <Key android:codes="-1" android:keyLabel="⇧"
            android:keyWidth="10%p" android:keyEdgeFlags="left"
            android:isModifier="true" android:isSticky="true"/>
        <Key android:codes="2957" android:keyLabel="ஔ" android:popupCharacters="ௌ"/>
        <Key android:codes="2963" android:keyLabel="ஓ" android:popupCharacters="ோ"/>
        <Key android:codes="2962" android:keyLabel="ஒ" android:popupCharacters="ொ"/>
        <Key android:codes="2997" android:keyLabel="வ"/>
