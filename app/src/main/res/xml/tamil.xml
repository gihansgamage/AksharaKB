        <Key android:codes="2959" android:keyLabel="ஏ" android:popupCharacters="ே"/>
        <Key android:codes="2995" android:keyLabel="ள"/>
        <Key android:codes="2993" android:keyLabel="ற"/>
        <Key android:codes="2985" android:keyLabel="ன"/>
        <Key android:codes="2975" android:keyLabel="ட"/>
        <Key android:codes="2979" android:keyLabel="ண" android:keyEdgeFlags="right"/>
    </Row>

    <Row>
        <Key android:codes="2949" android:keyLabel="அ" android:keyEdgeFlags="left"/>
        <Key android:codes="2951" android:keyLabel="இ" android:popupCharacters="ி"/>
        <Key android:codes="2953" android:keyLabel="உ" android:popupCharacters="ு"/>
        <Key android:codes="3021" android:keyLabel="்"/>
