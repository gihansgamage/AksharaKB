<?xml version="1.0" encoding="utf-8"?>
<!--
  Tamil Phonetic — English QWERTY. User types English, IME converts phonetically.
  a→அ, aa→ஆ, i→இ, ii→ஈ, u→உ, uu→ஊ, e→எ, ee→ஏ, ai→ஐ, o→ஒ, oo→ஓ, au→ஔ
  k/c→க, ng→ங, ch→ச, ny/nj→ஞ, t→ட, nn→ண, th→த, n→ந
  p→ப, m→ம, y→ய, r→ர, l→ல, v/w→வ, zh/z→ழ, ll→ள, rr→ற, nh→ன
-->
<Keyboard xmlns:android="http://schemas.android.com/apk/res/android"
    android:keyWidth="10%p"
    android:keyHeight="44dp"
    android:horizontalGap="0dp"
    android:verticalGap="0dp">

    <Row>
        <Key android:codes="49"  android:keyLabel="1"  android:popupCharacters="!" android:keyEdgeFlags="left"/>
        <Key android:codes="50"  android:keyLabel="2" android:popupCharacters="@"/>
        <Key android:codes="51"  android:keyLabel="3" android:popupCharacters="#"/>
        <Key android:codes="52"  android:keyLabel="4" android:popupCharacters="$"/>
        <Key android:codes="53"  android:keyLabel="5" android:popupCharacters="%"/>
        <Key android:codes="54"  android:keyLabel="6" android:popupCharacters="^"/>
        <Key android:codes="55"  android:keyLabel="7" android:popupCharacters="&amp;"/>
        <Key android:codes="56"  android:keyLabel="8" android:popupCharacters="*"/>
        <Key android:codes="57"  android:keyLabel="9" android:popupCharacters="("/>
        <Key android:codes="48"  android:keyLabel="0" android:popupCharacters=")" android:keyEdgeFlags="right"/>
    </Row>
    <Row>
        <Key android:codes="113" android:keyLabel="q" android:popupCharacters="Q"  android:keyEdgeFlags="left"/>
        <Key android:codes="119" android:keyLabel="w" android:popupCharacters="W"/>
        <Key android:codes="101" android:keyLabel="e" android:popupCharacters="E"/>
        <Key android:codes="114" android:keyLabel="r" android:popupCharacters="R"/>
        <Key android:codes="116" android:keyLabel="t" android:popupCharacters="T"/>
        <Key android:codes="121" android:keyLabel="y" android:popupCharacters="Y"/>
        <Key android:codes="117" android:keyLabel="u" android:popupCharacters="U"/>
        <Key android:codes="105" android:keyLabel="i" android:popupCharacters="I"/>
        <Key android:codes="111" android:keyLabel="o" android:popupCharacters="O"/>
        <Key android:codes="112" android:keyLabel="p" android:popupCharacters="P"  android:keyEdgeFlags="right"/>
    </Row>
    <Row>
        <Key android:codes="97"  android:keyLabel="a" android:popupCharacters="A"
            android:horizontalGap="5%p" android:keyEdgeFlags="left"/>
        <Key android:codes="115" android:keyLabel="s" android:popupCharacters="S"/>
        <Key android:codes="100" android:keyLabel="d" android:popupCharacters="D"/>
        <Key android:codes="102" android:keyLabel="f" android:popupCharacters="F"/>
        <Key android:codes="103" android:keyLabel="g" android:popupCharacters="G"/>
        <Key android:codes="104" android:keyLabel="h" android:popupCharacters="H"/>
        <Key android:codes="106" android:keyLabel="j" android:popupCharacters="J"/>
        <Key android:codes="107" android:keyLabel="k" android:popupCharacters="K"/>
        <Key android:codes="108" android:keyLabel="l" android:popupCharacters="L"  android:keyEdgeFlags="right"/>
    </Row>
    <Row>
        <Key android:codes="-1"  android:keyLabel="⇧"
            android:keyWidth="15%p" android:keyEdgeFlags="left"
            android:isModifier="true" android:isSticky="true"/>
        <Key android:codes="122" android:keyLabel="z" android:popupCharacters="Z"/>
        <Key android:codes="120" android:keyLabel="x" android:popupCharacters="X"/>
        <Key android:codes="99"  android:keyLabel="c" android:popupCharacters="C"/>
        <Key android:codes="118" android:keyLabel="v" android:popupCharacters="V"/>
        <Key android:codes="98"  android:keyLabel="b" android:popupCharacters="B"/>
        <Key android:codes="110" android:keyLabel="n" android:popupCharacters="N"/>
        <Key android:codes="109" android:keyLabel="m" android:popupCharacters="M"/>
        <Key android:codes="-5"  android:keyLabel="⌫"
            android:keyWidth="15%p" android:keyEdgeFlags="right"
            android:isRepeatable="true"/>
    </Row>
    <!-- Clean bottom row: 18+12+38+12+20=100 -->
    <Row android:rowEdgeFlags="bottom">
        <Key android:codes="-2"  android:keyLabel="\?123"
            android:keyWidth="18%p" android:keyEdgeFlags="left"/>
        <Key android:codes="44"  android:keyLabel=","
            android:keyWidth="12%p"/>
        <Key android:codes="32"  android:keyLabel="space"
            android:keyWidth="38%p"/>
        <Key android:codes="46"  android:keyLabel="."
            android:keyWidth="12%p"/>
        <Key android:codes="-4"  android:keyLabel="↵"
            android:keyWidth="20%p" android:keyEdgeFlags="right"/>
    </Row>

</Keyboard>