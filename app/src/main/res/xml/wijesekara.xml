        <Key android:codes="-5"   android:keyLabel="⌫"  android:keyWidth="14%p" android:keyEdgeFlags="right" android:isRepeatable="true"/>
    </Row>

    <!-- Vowel signs -->
    <Row>
        <Key android:codes="3461" android:keyLabel="අ" android:keyEdgeFlags="left"/>
        <Key android:codes="3462" android:keyLabel="ආ"/>
        <Key android:codes="3465" android:keyLabel="ඉ"/>
        <Key android:codes="3466" android:keyLabel="ඊ"/>
        <Key android:codes="3537" android:keyLabel="ැ"/>
