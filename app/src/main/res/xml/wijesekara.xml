<?xml version="1.0" encoding="utf-8"?>
<!--
  Smart Wijesekara Layout
  Changes from previous:
  - Number row: removed "-" and "=" keys → now exactly 10 keys × 10%p = 100%
  - Row 3: removed "." key → now ⇧(13%) + 8 keys × 9.25% + ⌫(13%) = 100%
  - All other rows unchanged
-->
<Keyboard xmlns:android="http://schemas.android.com/apk/res/android"
    android:keyWidth="10%p"
    android:keyHeight="44dp"
    android:horizontalGap="0dp"
    android:verticalGap="0dp">

    <!-- Number row: 10 keys × 10% = 100% (- and = removed) -->
    <Row>
        <Key android:codes="49" android:keyLabel="1" android:popupCharacters="!" android:keyEdgeFlags="left"/>
        <Key android:codes="50" android:keyLabel="2" android:popupCharacters="@"/>
        <Key android:codes="51" android:keyLabel="3" android:popupCharacters="#"/>
        <Key android:codes="52" android:keyLabel="4" android:popupCharacters="$"/>
        <Key android:codes="53" android:keyLabel="5" android:popupCharacters="%"/>
        <Key android:codes="54" android:keyLabel="6" android:popupCharacters="^"/>
        <Key android:codes="55" android:keyLabel="7" android:popupCharacters="&amp;"/>
        <Key android:codes="56" android:keyLabel="8" android:popupCharacters="*"/>
        <Key android:codes="57" android:keyLabel="9" android:popupCharacters="("/>
        <Key android:codes="48" android:keyLabel="0" android:popupCharacters=")" android:keyEdgeFlags="right"/>
    </Row>

    <!-- Row 1: 10 × 10% = 100%
         Normal: ු  අ  ැ  ර  එ  හ  ම  ස  ද  ච
         Shift:  ූ  උ  ෑ  ඍ  ඒ  ඓ  ඖ  ෂ  ධ  ඡ -->
    <Row>
        <Key android:codes="3540" android:keyLabel="ු" android:popupCharacters="්‍ර ූ" android:keyEdgeFlags="left"/>
        <Key android:codes="3461" android:keyLabel="අ" android:popupCharacters="උ"/>
        <Key android:codes="3536" android:keyLabel="ැ" android:popupCharacters="ෑ"/>
        <Key android:codes="3515" android:keyLabel="ර" android:popupCharacters="ඍ"/>
        <Key android:codes="3473" android:keyLabel="එ" android:popupCharacters="ඔ"/>
        <Key android:codes="3524" android:keyLabel="හ" android:popupCharacters="ශ ඥ"/>
        <Key android:codes="3512" android:keyLabel="ම" android:popupCharacters="ඹ ඖ"/>
        <Key android:codes="3523" android:keyLabel="ස" android:popupCharacters="ෂ"/>
        <Key android:codes="3503" android:keyLabel="ද" android:popupCharacters="ඳ ධ"/>
        <Key android:codes="3488" android:keyLabel="ච" android:popupCharacters="ඡ" android:keyEdgeFlags="right"/>
    </Row>

    <!-- Row 2: 10 × 10% = 100%
         Normal: ්  ි  ා  ෙ  ට  ය  ව  න  ක  ත
         Shift:  ා  ී  ෘ  ෆ  ඨ  ්‍ය  ළු  ණ  ඛ  ථ -->
    <Row>
        <Key android:codes="3530" android:keyLabel="්" android:popupCharacters="ෟ ්‍" android:keyEdgeFlags="left"/>
        <Key android:codes="3538" android:keyLabel="ි" android:popupCharacters="ී"/>
        <Key android:codes="3535" android:keyLabel="ා" android:popupCharacters="ෘ"/>
        <Key android:codes="3545" android:keyLabel="ෙ" android:popupCharacters="ෆ"/>
        <Key android:codes="3495" android:keyLabel="ට" android:popupCharacters="ඨ"/>
        <Key android:codes="3514" android:keyLabel="ය" android:popupCharacters="්ය"/>
        <Key android:codes="3520" android:keyLabel="ව" android:popupCharacters="ළු"/>
        <Key android:codes="3505" android:keyLabel="න" android:popupCharacters="ළ"/>
        <Key android:codes="3482" android:keyLabel="ක" android:popupCharacters="ඛ ඤ"/>
        <Key android:codes="3501" android:keyLabel="ත" android:popupCharacters="ථ" android:keyEdgeFlags="right"/>
    </Row>

    <!-- Row 3: ⇧(13%) + 8 keys × 9.25% + ⌫(13%) = 13+74+13 = 100%
         "." key removed; ග gets slightly more width
         Normal: ං  ජ  ඩ  ඉ  බ  ප  ල  ග
         Shift:  ඃ  ඣ  ඪ  ඊ  භ  ඵ  ළ  ඝ -->
    <Row>
        <Key android:codes="-1"   android:keyLabel="⇧"
            android:keyWidth="13%p" android:keyEdgeFlags="left"
            android:isModifier="true" android:isSticky="true"/>
        <Key android:codes="3458" android:keyLabel="ං"  android:keyWidth="9%p"  android:popupCharacters="ඃ"/>
        <Key android:codes="3490" android:keyLabel="ජ"  android:keyWidth="9%p"  android:popupCharacters="ඦ ඣ"/>
        <Key android:codes="3497" android:keyLabel="ඩ"  android:keyWidth="9%p"  android:popupCharacters="ඬ ඪ"/>
        <Key android:codes="3465" android:keyLabel="ඉ"  android:keyWidth="9%p"  android:popupCharacters="ඊ"/>
        <Key android:codes="3510" android:keyLabel="බ"  android:keyWidth="9%p"  android:popupCharacters="භ"/>
        <Key android:codes="3508" android:keyLabel="ප"  android:keyWidth="10%p" android:popupCharacters="ඵ"/>
        <Key android:codes="3517" android:keyLabel="ල"  android:keyWidth="10%p" android:popupCharacters="ළ ඹ"/>
        <Key android:codes="3484" android:keyLabel="ග"  android:keyWidth="9%p"  android:popupCharacters="ඟ ඝ"/>
        <Key android:codes="-5"   android:keyLabel="⌫"
            android:keyWidth="13%p" android:keyEdgeFlags="right"
            android:isRepeatable="true"/>
    </Row>

    <!-- Bottom: 18+12+38+12+20 = 100 -->
    <Row android:rowEdgeFlags="bottom">
        <Key android:codes="-2"  android:keyLabel="\?123" android:keyWidth="18%p" android:keyEdgeFlags="left"/>
        <Key android:codes="44"  android:keyLabel=","    android:keyWidth="12%p"/>
        <Key android:codes="32"  android:keyLabel="සිංහල" android:keyWidth="38%p"/>
        <Key android:codes="46"  android:keyLabel="."    android:keyWidth="12%p"/>
        <Key android:codes="-4"  android:keyLabel="↵"    android:keyWidth="20%p" android:keyEdgeFlags="right"/>
    </Row>

</Keyboard>