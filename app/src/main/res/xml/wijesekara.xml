        <Key android:codes="3516" android:keyLabel="ත"/>
        <Key android:codes="3527" android:keyLabel="ය"/>
        <Key android:codes="3467" android:keyLabel="උ"/>
        <Key android:codes="3538" android:keyLabel="ි"/>
        <Key android:codes="3549" android:keyLabel="ෝ" android:keyEdgeFlags="right"/>
