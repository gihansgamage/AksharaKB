    <Row android:rowEdgeFlags="bottom">
        <Key android:codes="-2"  android:keyLabel="\?123" android:keyWidth="15%p" android:keyEdgeFlags="left"/>
        <Key android:codes="-10" android:keyLabel="🌐"   android:keyWidth="11%p"/>
        <Key android:codes="-20" android:keyLabel="📋"   android:keyWidth="11%p"/>
        <Key android:codes="32"  android:keyLabel="space" android:keyWidth="32%p"/>
