        <Key android:codes="3484" android:keyLabel="ග"/>
        <Key android:codes="3524" android:keyLabel="හ"/>
        <Key android:codes="3490" android:keyLabel="ජ"/>
        <Key android:codes="3482" android:keyLabel="ක"/>
        <Key android:codes="3517" android:keyLabel="ල"/>
        <Key android:codes="3526" android:keyLabel="ළ" android:keyEdgeFlags="right"/>
    </Row>

    <!-- Row 3: ⇧  ෂ  ච  ව  බ  න  ම  ⌫ -->
    <Row>
        <Key android:codes="-1"   android:keyLabel="⇧"  android:keyWidth="14%p" android:keyEdgeFlags="left" android:isModifier="true" android:isSticky="true"/>
        <Key android:codes="3530" android:keyLabel="ෂ"/>
        <Key android:codes="3491" android:keyLabel="ච"/>
        <Key android:codes="3519" android:keyLabel="ව"/>
