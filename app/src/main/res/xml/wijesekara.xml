<?xml version="1.0" encoding="utf-8"?>
<!--
  Wijesekara Sinhala Layout — standard Sri Lankan keyboard standard
  Rows match the physical key positions of the official Wijesekara layout.
-->
<Keyboard xmlns:android="http://schemas.android.com/apk/res/android"
    android:keyWidth="10%p"
    android:keyHeight="54dp"
    android:horizontalGap="3dp"
    android:verticalGap="3dp">

    <!-- Row 1: ූ  ෑ  ්  ඍ  ර  ත  ය  උ  ි  ො -->
