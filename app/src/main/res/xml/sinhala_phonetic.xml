<?xml version="1.0" encoding="utf-8"?>
<!--
  Sinhala Smart Phonetic Layout
  Mapped to familiar QWERTY positions by pronunciation:
  Row 1: ට ව එ ර ත ය උ ඉ ඔ ප
  Row 2: අ ස ද ෆ ග හ ජ ක ල
  Row 3: ෂ ශ ඩ ච ඝ බ න ම
  Vowel row: ා ැ ි ූ ේ ො ් ං ඃ ෲ
  Bottom: ?123  🌐  📋  space  .  ↵
-->
<Keyboard xmlns:android="http://schemas.android.com/apk/res/android"
    android:keyWidth="10%p"
    android:keyHeight="54dp"
    android:horizontalGap="3dp"
    android:verticalGap="3dp">

    <!-- Row 1 – consonants (q→ට  w→ව  e→එ  r→ර  t→ත  y→ය  u→උ  i→ඉ  o→ඔ  p→ප) -->
    <Row>
        <Key android:codes="3522" android:keyLabel="ට" android:keyEdgeFlags="left"/>
        <Key android:codes="3520" android:keyLabel="ව"/>
        <Key android:codes="3462" android:keyLabel="ඇ"/>
        <Key android:codes="3515" android:keyLabel="ර"/>
        <Key android:codes="3516" android:keyLabel="ත"/>
        <Key android:codes="3527" android:keyLabel="ය"/>
        <Key android:codes="3467" android:keyLabel="උ"/>
        <Key android:codes="3465" android:keyLabel="ඉ"/>
        <Key android:codes="3470" android:keyLabel="ඔ"/>
        <Key android:codes="3508" android:keyLabel="ප" android:keyEdgeFlags="right"/>
    </Row>

    <!-- Row 2 – a→අ  s→ස  d→ද  f→ෆ  g→ග  h→හ  j→ජ  k→ක  l→ල -->
    <Row>
        <Key android:codes="3461" android:keyLabel="අ" android:horizontalGap="5%p" android:keyEdgeFlags="left"/>
        <Key android:codes="3523" android:keyLabel="ස"/>
        <Key android:codes="3521" android:keyLabel="ද"/>
        <Key android:codes="3536" android:keyLabel="ා"/>
        <Key android:codes="3484" android:keyLabel="ග"/>
        <Key android:codes="3524" android:keyLabel="හ"/>
        <Key android:codes="3490" android:keyLabel="ජ"/>
        <Key android:codes="3482" android:keyLabel="ක"/>
        <Key android:codes="3517" android:keyLabel="ල" android:keyEdgeFlags="right"/>
    </Row>

    <!-- Row 3 – shift + z→ෂ  x→ශ  c→ච  v→ව  b→බ  n→න  m→ම  del -->
    <Row>
        <Key android:codes="-1"   android:keyLabel="⇧"  android:keyWidth="14%p" android:keyEdgeFlags="left" android:isModifier="true" android:isSticky="true"/>
        <Key android:codes="3530" android:keyLabel="ෂ"/>
        <Key android:codes="3529" android:keyLabel="ශ"/>
        <Key android:codes="3491" android:keyLabel="ච"/>
        <Key android:codes="3519" android:keyLabel="ව"/>
        <Key android:codes="3494" android:keyLabel="බ"/>
        <Key android:codes="3505" android:keyLabel="න"/>
        <Key android:codes="3512" android:keyLabel="ම"/>
        <Key android:codes="-5"   android:keyLabel="⌫"  android:keyWidth="14%p" android:keyEdgeFlags="right" android:isRepeatable="true"/>
    </Row>

    <!-- Vowel signs row -->
    <Row>
        <Key android:codes="3535" android:keyLabel="ා" android:keyEdgeFlags="left"/>
        <Key android:codes="3537" android:keyLabel="ැ"/>
        <Key android:codes="3538" android:keyLabel="ි"/>
        <Key android:codes="3539" android:keyLabel="ී"/>
        <Key android:codes="3540" android:keyLabel="ු"/>
        <Key android:codes="3541" android:keyLabel="ූ"/>
        <Key android:codes="3545" android:keyLabel="ේ"/>
        <Key android:codes="3548" android:keyLabel="ො"/>
        <Key android:codes="3534" android:keyLabel="්"/>
        <Key android:codes="3530" android:keyLabel="ං" android:keyEdgeFlags="right"/>
    </Row>

    <!-- Bottom -->
    <Row android:rowEdgeFlags="bottom">
        <Key android:codes="-2"  android:keyLabel="\?123" android:keyWidth="15%p" android:keyEdgeFlags="left"/>
        <Key android:codes="-10" android:keyLabel="🌐"   android:keyWidth="11%p"/>
        <Key android:codes="-20" android:keyLabel="📋"   android:keyWidth="11%p"/>
        <Key android:codes="32"  android:keyLabel="space" android:keyWidth="32%p"/>
        <Key android:codes="46"  android:keyLabel="."    android:keyWidth="10%p"/>
        <Key android:codes="-4"  android:keyLabel="↵"   android:keyWidth="21%p" android:keyEdgeFlags="right"/>
    </Row>

</Keyboard>